---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import PartnersTicker from '../components/PartnersTicker';
import Footer from '../components/Footer';
---

<Layout title="PRISMA Global Club | Aliados">
  <Navbar client:load />
  
  <div class="relative z-10 pt-48 px-6 max-w-[1400px] mx-auto min-h-[50vh]">
    <div class="flex items-center gap-6 mb-12">
      <span class="text-[11px] uppercase tracking-[0.6em] text-prisma-dark-red font-bold">
        Pestaña 5: Alianzas y Partners
      </span>
      <div class="flex-1 h-[1px] bg-prisma-dark-red/10" />
    </div>
    <h1 class="text-6xl md:text-8xl text-prisma-dark-red font-display leading-[1.1] mb-8">
      RED DE <span class="text-prisma-light-red">CONTACTOS</span>
    </h1>
    <p class="text-xl text-prisma-dark-red/60 font-body max-w-2xl mb-16">
      Detalle de las conexiones de PRISMA, explicando de forma breve nuestras afiliaciones y convenios institucionales (ej. ONGs, Empresas, Universidades).
    </p>

    <!-- Placeholder para Lista de Aliados -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 py-12 border-t border-prisma-dark-red/10">
      <div class="p-8 glass rounded-2xl flex flex-col items-center justify-center min-h-[250px] text-center">
        <div class="w-24 h-24 rounded-full bg-prisma-dark-red/5 mb-6 flex items-center justify-center text-xs text-prisma-dark-red/40">Logo_Socio1.png</div>
        <h3 class="text-xl font-display text-prisma-dark-red mb-2">Nombre del Partner</h3>
        <p class="text-[11px] uppercase tracking-[0.2em] text-prisma-dark-red/60">TIPO DE ALIANZA</p>
      </div>
    </div>
  </div>

  <!-- Marquee de Co-Branding -->
  <PartnersTicker client:only="react" />
  
  <Footer hideCta={true} client:load />

  <div class="fixed inset-0 pointer-events-none z-[9999] opacity-[0.03] mix-blend-overlay">
    <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <filter id="noiseFilter">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
      </filter>
      <rect width="100%" height="100%" filter="url(#noiseFilter)" />
    </svg>
  </div>
</Layout>
